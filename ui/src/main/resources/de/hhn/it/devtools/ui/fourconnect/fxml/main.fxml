<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="de.hhn.it.devtools.ui.fourconnect.controller.MainMenuController"
            prefWidth="900" prefHeight="600"
            style="-fx-background-color: #d9d9d9;">

  <top>
    <HBox BorderPane.alignment="CENTER_RIGHT">
      <padding>
        <Insets top="18" right="22" bottom="0" left="0"/>
      </padding>

      <!-- Power icon (als Text) -->
      <Button text="⏻"
              onAction="#onExitApp"
              style="-fx-font-size: 28px;
                     -fx-background-color: transparent;
                     -fx-text-fill: #cc0000;
                     -fx-font-weight: bold;"/>
    </HBox>
  </top>

  <center>
    <VBox alignment="CENTER" spacing="22">
      <Button text="New Game"
              onAction="#onNewGame"
              prefWidth="320" prefHeight="72"
              style="-fx-background-color: #47d10c;
                     -fx-text-fill: black;
                     -fx-font-size: 26px;
                     -fx-font-weight: bold;
                     -fx-background-radius: 10;"/>

      <Button text="Load Game"
              onAction="#onLoadGame"
              prefWidth="320" prefHeight="72"
              style="-fx-background-color: #e0a000;
                     -fx-text-fill: black;
                     -fx-font-size: 26px;
                     -fx-font-weight: bold;
                     -fx-background-radius: 10;"/>
    </VBox>
  </center>

</BorderPane>
