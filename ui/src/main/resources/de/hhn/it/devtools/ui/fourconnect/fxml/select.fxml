<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="de.hhn.it.devtools.ui.fourconnect.controller.SelectController">

  <VBox alignment="CENTER" spacing="25">
    <Label fx:id="titleLabel"
           text="Player 1: Select your Character"
           style="-fx-font-size: 24; -fx-background-color: #0b2b63; -fx-text-fill: white; -fx-padding: 18 30; -fx-background-radius: 12;"/>

    <HBox alignment="CENTER" spacing="40">
      <Button text="RED"
              onAction="#selectRed"
              style="-fx-font-size: 22; -fx-background-color: #e53935; -fx-text-fill: white; -fx-padding: 30 70;"/>
      <Button text="YELLOW"
              onAction="#selectYellow"
              style="-fx-font-size: 22; -fx-background-color: #fbc02d; -fx-text-fill: black; -fx-padding: 30 70;"/>
    </HBox>

    <Button text="Back"
            onAction="#back"
            style="-fx-font-size: 16; -fx-padding: 10 25;"/>
  </VBox>

</StackPane>
