<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1" maxHeight="680.0" maxWidth="1080.0"
            minHeight="680.0" minWidth="1080.0" prefHeight="680.0" prefWidth="1080.0"
            fx:id="templateAnchorPane"
            fx:controller="de.hhn.it.devtools.javafx.controllers.TowerDefenseController">
    <VBox layoutX="458.0" layoutY="301.0" alignment="CENTER">
    <Label text="Tower Defense">
        <font>
            <Font name="Roboto Medium" size="64.0"/>
        </font>
    </Label>
    <Button text="Start Game"
            onAction="#startGameButton"
            prefWidth="200"/>
    </VBox>
