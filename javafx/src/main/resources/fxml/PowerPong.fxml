<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="rootStack" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="de.hhn.it.devtools.javafx.controllers.PowerPongController">
   <children>
      <Canvas fx:id="gameCanvas" height="600.0" width="800.0" />
      <Label fx:id="scoreLabel" text="P1: 0 - P2: 0" textFill="WHITE" StackPane.alignment="TOP_CENTER" translateY="20.0" visible="false">
         <font>
            <Font name="Monospaced Bold" size="36.0" />
         </font>
      </Label>
      <VBox fx:id="gameOverBox" alignment="CENTER" spacing="20.0" style="-fx-background-color: rgba(0,0,0,0.8);" visible="false">
         <children>
            <Label fx:id="winnerLabel" text="PLAYER 1 WINS!" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="64.0" />
               </font>
            </Label>
            <Button mnemonicParsing="false" onAction="#onBackToMenu" text="Back to Menu">
               <font>
                  <Font size="24.0" />
               </font>
            </Button>
         </children>
      </VBox>
      <VBox fx:id="menuBox" alignment="CENTER" spacing="20.0" style="-fx-background-color: rgba(255,255,255,0.9);">
         <children>
            <Label text="PowerPong">
               <font>
                  <Font name="System Bold" size="64.0" />
               </font>
            </Label>
            <Button fx:id="btnStart" mnemonicParsing="false" onAction="#onStartGame" prefWidth="300.0" text="Start Game">
               <font>
                  <Font size="24.0" />
               </font>
            </Button>
         </children>
      </VBox>
   </children>
</StackPane>
