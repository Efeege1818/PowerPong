<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<AnchorPane prefHeight="600" prefWidth="800" style="-fx-background-color: #1a1a1e;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">

    <children>

        <!-- HUD Background -->
        <Rectangle fx:id="hudBackground" layoutX="0" layoutY="4" width="800" height="50" arcWidth="15" arcHeight="15" fill="rgba(0,0,0,0.75)" />

        <!-- XP Bar Background -->
        <Rectangle
                layoutX="200"
                layoutY="40"
                width="400"
                height="8"
                arcWidth="8"
                arcHeight="8"
                fill="#333333" />

        <!-- XP Bar Foreground -->
        <Rectangle
                fx:id="xpBar"
                layoutX="200"
                layoutY="40"
                width="0"
                height="8"
                arcWidth="8"
                arcHeight="8"
                fill="linear-gradient(to right, #4facfe, #00f2fe)" />

        <!-- Timer -->
        <Label layoutX="360" layoutY="15" style="-fx-text-fill: gold; -fx-font-size: 18px;" text="Time:" />
        <Label fx:id="timeLabel" layoutX="420" layoutY="15" style="-fx-text-fill: gold; -fx-font-size: 18px;" text="00:00" />

        <!-- Score -->
        <Label layoutX="15" layoutY="15" style="-fx-text-fill: lime; -fx-font-size: 18px;" text="Score:" />

        <Label fx:id="scoreLabel" layoutX="75" layoutY="15"
               style="-fx-text-fill: lime; -fx-font-size: 18px; -fx-effect: dropshadow(one-pass-box, black, 3, 0.3, 1, 1);"
               text="0" />

        <!-- Level -->
        <Label layoutX="695.0" layoutY="19.0" style="-fx-text-fill: lime; -fx-font-size: 18px;" text="Level:" />

        <Label fx:id="levelLabel" layoutX="746.0" layoutY="19.0" style="-fx-text-fill: lime; -fx-font-size: 18px; -fx-effect: dropshadow(one-pass-box, black, 3, 0.3, 1, 1);" text="1"  />

        <!-- Main Canvas -->
        <Canvas fx:id="canvas" height="512" layoutX="144" layoutY="64" width="512" />

    </children>
</AnchorPane>
