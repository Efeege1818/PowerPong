<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="spaceInvadersPane" maxHeight="682.0" maxWidth="1080.0" minHeight="680.0" minWidth="1080.0" prefHeight="680.0" prefWidth="1080.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="de.hhn.it.devtools.javafx.controllers.SpaceInvadersController">
   <children>
      <ImageView fx:id="logo" fitHeight="150.0" fitWidth="200.0" layoutX="440.0" layoutY="48.0" nodeOrientation="INHERIT" pickOnBounds="true" preserveRatio="true">
         <cursor>
            <Cursor fx:constant="CLOSED_HAND" />
         </cursor></ImageView>
      <Button fx:id="spaceInvadersButton" layoutX="404.0" layoutY="340.0" mnemonicParsing="false" onAction="#doActionStart" prefHeight="154.0" prefWidth="275.0" style="-fx-background-color: linear-gradient(to bottom, #FFD700, #FFA500);                -fx-text-fill: #1A1A1A;                -fx-font-family: 'Montserrat', 'Arial Black', sans-serif;                -fx-font-weight: bold;                -fx-font-size: 26px;                -fx-background-radius: 25;                -fx-border-color: #FFED4A;                -fx-border-width: 3;                -fx-border-radius: 25;                -fx-effect: dropshadow(three-pass-box, #D4AF37, 1, 0.6, 0, 8);                -fx-cursor: hand;                -fx-padding: 15 30 15 30;" text="Start Game" />
      <ChoiceBox fx:id="difficultyChoiceBox" layoutX="465.0" layoutY="237.0" prefWidth="150.0" style="-fx-background-color: linear-gradient(to bottom, #FFD700, #FFA500);                   -fx-text-fill: #1A1A1A;                   -fx-font-family: 'Arial', sans-serif;                   -fx-font-weight: bold;                   -fx-font-size: 16px;                   -fx-background-radius: 20;                   -fx-border-color: #FFED4A;                   -fx-border-width: 2.5;                   -fx-border-radius: 20;                   -fx-effect: dropshadow(three-pass-box, #D4AF37, 1, 0.5, 0, 5);                   -fx-cursor: hand;                   -fx-padding: 8 15 8 15;" />
      <Label fx:id="infoLabel" layoutX="739.0" layoutY="213.0" prefHeight="100.0" prefWidth="200.0" style="-fx-background-color: linear-gradient(to bottom, #2c1810, #1a0f08);
              -fx-border-color: #ffd700;
              -fx-border-width: 2;
              -fx-background-radius: 4;
              -fx-padding: 12 10 12 10;
              -fx-font-family: 'Courier New', monospace;
              -fx-font-size: 16px;
              -fx-font-weight: bold;
              -fx-text-fill: #ffd700;
              -fx-alignment: top-left;
              -fx-effect: dropshadow(three-pass-box, #ffd700, 8, 0.6, 0, 0);"
             wrapText="true"/>
   </children>
</AnchorPane>
