<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<fx:root prefWidth="1280.0" prefHeight="720.0"
         type="AnchorPane"
         xmlns="http://javafx.com/javafx/17.0.12"
         xmlns:fx="http://javafx.com/fxml/1"
         style="-fx-background-color: white;">

    <children>
        <!-- Dieses Pane ist das "Design" auf 1280x720. DAS wird skaliert -->
        <AnchorPane fx:id="designPane" prefWidth="1280.0" prefHeight="720.0">

            <children>

                <Label fx:id="turnLabel" layoutX="60.0" layoutY="5.0" text="Player 1 turn" textFill="RED">
                    <font><Font name="System Bold" size="50.0"/></font>
                </Label>

                <!-- ===================== Player 2 (oben rechts) ===================== -->
                <Label fx:id="player2NameLabel" layoutX="850.0" layoutY="40.0" text="Player 2" textFill="#006fff">
                    <font><Font size="28.0"/></font>
                </Label>

                <ProgressBar fx:id="player2HpBar"
                             layoutX="850.0" layoutY="80.0"
                             prefWidth="200.0" prefHeight="18.0"
                             progress="0.40"
                             style="-fx-accent: #bfbfbf;"/>
                <Region layoutX="850.0" layoutY="80.0"
                        prefWidth="204.0" prefHeight="22.0"
                        style="-fx-border-color: #111; -fx-border-width: 2; -fx-background-color: transparent;"/>

                <Region fx:id="player2DebuffIcon"
                        layoutX="850.0" layoutY="110.0"
                        prefWidth="22.0" prefHeight="22.0"
                        style="-fx-border-color: #111; -fx-border-width: 3;
                               -fx-border-radius: 50; -fx-background-radius: 50;
                               -fx-background-color: transparent;"/>

                <Label fx:id="player2DebuffLabel" layoutX="880.0" layoutY="110.0" text="DEF +3" textFill="#18a600">
                    <font><Font size="16.0"/></font>
                </Label>

                <!-- Monster Player 2: etwas größer als Screenshot -->
                <ImageView fx:id="player2MonsterImage"
                           layoutX="850.0" layoutY="135.0"
                           fitWidth="200.0" fitHeight="200.0"
                           pickOnBounds="true" preserveRatio="true" smooth="true">
                    <image>
                        <Image url="@../Monster%20Sprites/PflanzeMon.png"/>
                    </image>
                </ImageView>

                <!-- ===================== Player 1 (links unten / Mitte) ===================== -->

                <!-- Monster Player 1: etwas größer als Screenshot -->
                <ImageView fx:id="player1MonsterImage"
                           layoutX="125.0" layoutY="50.0"
                           fitWidth="300.0" fitHeight="300.0"
                           pickOnBounds="true" preserveRatio="true" smooth="true">
                    <image>
                        <Image url="@../Monster%20Sprites/FeuerMon Back.png"/>
                    </image>
                </ImageView>

                <Region fx:id="player1BuffIcon"
                        layoutX="100.0" layoutY="330.0"
                        prefWidth="22.0" prefHeight="22.0"
                        style="-fx-border-color: #111; -fx-border-width: 3;
                               -fx-border-radius: 50; -fx-background-radius: 50;
                               -fx-background-color: transparent;"/>

                <Label fx:id="player1BuffLabel" layoutX="130.0" layoutY="330.0" text="Krit +3" textFill="RED">
                    <font><Font size="16.0"/></font>
                </Label>

                <ProgressBar fx:id="player1HpBar"
                             layoutX="100.0" layoutY="360.0"
                             prefWidth="180.0" prefHeight="18.0"
                             progress="0.35"
                             style="-fx-accent: #bfbfbf;"/>
                <Region layoutX="98.0" layoutY="360.0"
                        prefWidth="184.0" prefHeight="22.0"
                        style="-fx-border-color: #111; -fx-border-width: 2; -fx-background-color: transparent;"/>

                <Label fx:id="player1NameLabel" layoutX="150.0" layoutY="380.0" text="Player 1" textFill="RED">
                    <font><Font size="28.0"/></font>
                </Label>

                <!-- ===================== Buttons wie Screenshot ===================== -->

                <Button fx:id="btnElementalAtk"
                        layoutX="20.0" layoutY="440.0"
                        prefWidth="580.0" prefHeight="78.0"
                        mnemonicParsing="false"
                        text="Fire Attack"
                        style="-fx-background-color: #c51b1b; -fx-text-fill: white;
                               -fx-font-size: 20px; -fx-font-weight: 700;
                               -fx-border-color: #111; -fx-border-width: 2;
                               -fx-background-radius: 6; -fx-border-radius: 6;" />
                <Label text="Q" layoutX="35.0" layoutY="452.0" textFill="#111111">
                    <font><Font name="System Bold" size="48.0"/></font>
                </Label>

                <Button fx:id="btnNormalAtk"
                        layoutX="650.0" layoutY="440.0"
                        prefWidth="580.0" prefHeight="78.0"
                        mnemonicParsing="false"
                        text="Dot Fire"
                        style="-fx-background-color: #c51b1b; -fx-text-fill: white;
                               -fx-font-size: 20px; -fx-font-weight: 700;
                               -fx-border-color: #111; -fx-border-width: 2;
                               -fx-background-radius: 6; -fx-border-radius: 6;" />
                <Label text="W" layoutX="665.0" layoutY="452.0" textFill="#111111">
                    <font><Font name="System Bold" size="48.0"/></font>
                </Label>

                <Button fx:id="btnBuffCrit"
                        layoutX="20.0" layoutY="535.0"
                        prefWidth="580.0" prefHeight="78.0"
                        mnemonicParsing="false"
                        text="Critical Buff"
                        style="-fx-background-color: #c51b1b; -fx-text-fill: white;
                               -fx-font-size: 20px; -fx-font-weight: 700;
                               -fx-border-color: #111; -fx-border-width: 2;
                               -fx-background-radius: 6; -fx-border-radius: 6;" />
                <Label text="A" layoutX="35.0" layoutY="547.0" textFill="#111111">
                    <font><Font name="System Bold" size="48.0"/></font>
                </Label>

                <Button fx:id="btnDebuffHit"
                        layoutX="650.0" layoutY="535.0"
                        prefWidth="580.0" prefHeight="78.0"
                        mnemonicParsing="false"
                        text="Defense Debuff"
                        style="-fx-background-color: #c51b1b; -fx-text-fill: white;
                               -fx-font-size: 20px; -fx-font-weight: 700;
                               -fx-border-color: #111; -fx-border-width: 2;
                               -fx-background-radius: 6; -fx-border-radius: 6;" />
                <Label text="S" layoutX="665.0" layoutY="547.0" textFill="#111111">
                    <font><Font name="System Bold" size="48.0"/></font>
                </Label>

                <Button fx:id="btnSpecialAtk"
                        layoutX="20.0" layoutY="625.0"
                        prefWidth="1220.0" prefHeight="70.0"
                        mnemonicParsing="false"
                        text="Strong Fire Attack- 3/6"
                        style="-fx-background-color: #8b00ff; -fx-text-fill: white;
                               -fx-font-size: 20px; -fx-font-weight: 800;
                               -fx-border-color: #111; -fx-border-width: 2;
                               -fx-background-radius: 6; -fx-border-radius: 6;" />
                <Label text="D" layoutX="35.0" layoutY="625.0" textFill="#111111">
                    <font><Font name="System Bold" size="48.0"/></font>
                </Label>

            </children>
        </AnchorPane>
    </children>
</fx:root>
