<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.Glow?>
<?import javafx.scene.text.Font?>

<fx:root type="StackPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
         style="-fx-background-color: rgb(5, 5, 25);">
   <children>
      <Canvas fx:id="gameCanvas" height="600.0" width="800.0" />
      
      <!-- HUD / In-Game Overlay -->
      <Label fx:id="scoreLabel" text="0 : 0" textFill="WHITE" StackPane.alignment="TOP_CENTER" translateY="30.0" visible="false">
         <font>
            <Font name="Courier New Bold" size="48.0" />
         </font>
         <effect>
            <javafx.scene.effect.Glow level="0.8" />
         </effect>
      </Label>
      


      <!-- Game Over Overlay -->
      <VBox fx:id="gameOverBox" alignment="CENTER" spacing="25.0" style="-fx-background-color: rgba(0, 0, 0, 0.85);" visible="false">
         <children>
            <Label fx:id="winnerLabel" text="WINNER" textFill="WHITE">
               <font>
                  <Font name="Arial Black" size="64.0" />
               </font>
               <effect>
                  <javafx.scene.effect.DropShadow color="WHITE" radius="20" spread="0.4" />
               </effect>
            </Label>
            
            <HBox alignment="CENTER" spacing="20.0">
                <Button mnemonicParsing="false" onAction="#onRestartGame" text="REMATCH" style="-fx-background-color: transparent; -fx-text-fill: #00f3ff; -fx-border-color: #00f3ff; -fx-border-width: 2px; -fx-border-radius: 5; -fx-padding: 10 30; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 18px;">
                   <effect>
                      <javafx.scene.effect.Glow level="0.5"/>
                   </effect>
                </Button>
                <Button mnemonicParsing="false" onAction="#onBackToMenu" text="MENU" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-width: 2px; -fx-border-radius: 5; -fx-padding: 10 30; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 18px;">
                </Button>
            </HBox>
         </children>
      </VBox>

      <!-- Main Menu (Premium Glassmorphism Style) -->
      <StackPane fx:id="menuDecorations" mouseTransparent="true" visible="true">
         <children>
             <!-- Subtle glowing background orb effect for atmosphere -->
             <javafx.scene.shape.Circle radius="300" fill="radial-gradient(focus-distance 0% , center 50% 50% , radius 50% , rgba(0, 243, 255, 0.1), transparent)" />
         </children>
      </StackPane>

      <VBox fx:id="menuBox" alignment="CENTER" spacing="20.0" visible="true" 
            maxWidth="Infinity" maxHeight="Infinity">
         <style>
            -fx-background-color: linear-gradient(to bottom, rgb(5, 5, 25), rgb(15, 10, 35));
            -fx-padding: 40;
         </style>
         <children>
            <!-- Logo Section -->
            <VBox alignment="CENTER" spacing="5">
                <Label text="POWER" textFill="WHITE">
                   <font>
                      <Font name="Arial Black" size="52.0" />
                   </font>
                   <effect>
                      <javafx.scene.effect.DropShadow color="#00f3ff" radius="15" spread="0.3" />
                   </effect>
                </Label>
                <Label text="PONG" textFill="WHITE" translateY="-15">
                   <font>
                      <Font name="Arial Black" size="52.0" />
                   </font>
                   <effect>
                      <javafx.scene.effect.DropShadow color="#ff00ff" radius="15" spread="0.3" />
                   </effect>
                </Label>
            </VBox>

            <!-- Menu Buttons -->
            <VBox spacing="12.0" alignment="CENTER" maxWidth="600">
                <!-- Classic Mode -->
                <Button mnemonicParsing="false" onAction="#onStartClassic" text="🎮 CLASSIC DUEL" maxWidth="Infinity" prefHeight="50" style="-fx-background-color: linear-gradient(to bottom, rgba(0, 243, 255, 0.3), rgba(0, 150, 200, 0.15)); -fx-text-fill: #00f3ff; -fx-font-weight: bold; -fx-font-size: 18px; -fx-background-radius: 25; -fx-cursor: hand; -fx-border-color: #00f3ff; -fx-border-radius: 25; -fx-border-width: 2;">
                    <effect>
                        <javafx.scene.effect.DropShadow color="#00f3ff" radius="12" spread="0.2"/>
                    </effect>
                </Button>
                
                <!-- VS AI with Difficulty Levels -->
                <VBox spacing="8" alignment="CENTER" style="-fx-background-color: rgba(10, 255, 10, 0.08); -fx-background-radius: 15; -fx-padding: 12;">
                    <Label text="🤖 PLAYER VS AI" textFill="#0aff0a" style="-fx-font-weight: bold; -fx-font-size: 15;">
                        <effect>
                            <javafx.scene.effect.Glow level="0.5"/>
                        </effect>
                    </Label>
                    <HBox spacing="10" alignment="CENTER">
                        <Button mnemonicParsing="false" onAction="#onStartVsAiEasy" text="😊 Einfach" prefWidth="100" prefHeight="38" style="-fx-background-color: linear-gradient(to bottom, rgba(100, 255, 100, 0.25), rgba(50, 200, 50, 0.1)); -fx-text-fill: #7fff7f; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand; -fx-border-color: #7fff7f; -fx-border-radius: 20; -fx-border-width: 1.5;"/>
                        <Button mnemonicParsing="false" onAction="#onStartVsAiMedium" text="😐 Mittel" prefWidth="100" prefHeight="38" style="-fx-background-color: linear-gradient(to bottom, rgba(255, 200, 50, 0.3), rgba(200, 150, 30, 0.15)); -fx-text-fill: #ffc832; -fx-font-weight: bold; -fx-font-size: 12px; -fx-background-radius: 20; -fx-cursor: hand; -fx-border-color: #ffc832; -fx-border-radius: 20; -fx-border-width: 1.5;"/>
                        <Button mnemonicParsing="false" onAction="#onStartVsAiHard" text="😈 Schwer" prefWidth="100" prefHeight="38" style="-fx-background-color: linear-gradient(to bottom, rgba(255, 80, 80, 0.35), rgba(200, 50, 50, 0.15)); -fx-text-fill: #ff6464; -fx-font-weight: bold; -fx-font-size: 12px; -fx-background-radius: 20; -fx-cursor: hand; -fx-border-color: #ff6464; -fx-border-radius: 20; -fx-border-width: 1.5;"/>
                    </HBox>
                </VBox>
                
                <!-- Power-Up Mode (Featured) - Most prominent -->
                <Button mnemonicParsing="false" onAction="#onStartPowerUp" text="⚡ POWER-UP CHAOS ⚡" maxWidth="Infinity" prefHeight="60" style="-fx-background-color: linear-gradient(to right, #ff00cc, #6600ff, #00ccff); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 22px; -fx-background-radius: 30; -fx-cursor: hand; -fx-border-color: white; -fx-border-radius: 30; -fx-border-width: 2;">
                    <effect>
                        <javafx.scene.effect.DropShadow color="#ff00ff" radius="20" spread="0.3"/>
                    </effect>
                </Button>
                
                <!-- Survival -->
                <Button mnemonicParsing="false" onAction="#onStartSurvival" text="💀 SURVIVAL" maxWidth="Infinity" prefHeight="50" style="-fx-background-color: linear-gradient(to bottom, rgba(255, 220, 0, 0.3), rgba(200, 150, 0, 0.15)); -fx-text-fill: #ffdc00; -fx-font-weight: bold; -fx-font-size: 18px; -fx-background-radius: 25; -fx-cursor: hand; -fx-border-color: #ffdc00; -fx-border-radius: 25; -fx-border-width: 2;">
                    <effect>
                        <javafx.scene.effect.DropShadow color="#ffdc00" radius="10" spread="0.15"/>
                    </effect>
                </Button>
            </VBox>
            
            <!-- Controls Help -->
            <VBox alignment="CENTER" spacing="5" style="-fx-padding: 15 0 0 0;">
                <Label text="STEUERUNG" textFill="#888888" style="-fx-font-weight: bold; -fx-font-size: 12;"/>
                <HBox alignment="CENTER" spacing="40">
                    <VBox alignment="CENTER" spacing="2">
                        <Label text="SPIELER 1" textFill="#00f3ff" style="-fx-font-weight: bold; -fx-font-size: 11;"/>
                        <Label text="W / S" textFill="#aaaaaa" style="-fx-font-size: 14;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="2">
                        <Label text="SPIELER 2" textFill="#ff00ff" style="-fx-font-weight: bold; -fx-font-size: 11;"/>
                        <Label text="↑ / ↓" textFill="#aaaaaa" style="-fx-font-size: 14;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="2">
                        <Label text="PAUSE" textFill="#ffff00" style="-fx-font-weight: bold; -fx-font-size: 11;"/>
                        <Label text="P" textFill="#aaaaaa" style="-fx-font-size: 14;"/>
                    </VBox>
                </HBox>
            </VBox>
            
            <!-- Footer -->
            <HBox alignment="CENTER" spacing="20.0">
                 <padding>
                     <Insets top="5.0" />
                 </padding>
                 <Button mnemonicParsing="false" onAction="#onExitGame" text="✕ EXIT" style="-fx-background-color: transparent; -fx-text-fill: #ff4444; -fx-font-size: 12px; -fx-cursor: hand; -fx-font-weight: bold;"/>
            </HBox>
         </children>
      </VBox>
   </children>
</fx:root>